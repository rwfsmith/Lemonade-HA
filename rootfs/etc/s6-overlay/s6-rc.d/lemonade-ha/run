#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Lemonade HA add-on
# Installs the custom integration into HA config dir, then sleeps.
# ==============================================================================

# ── Find HA config directory ──────────────────────────────────────────────────
# Locate the real HA config dir by looking for configuration.yaml.
# In current HA OS, homeassistant:rw mounts at /homeassistant.
# In older supervisor or with config:rw, the HA config is at /config.
bashio::log.info "Searching for HA config directory ..."
bashio::log.info "  /homeassistant exists: $([ -d /homeassistant ] && echo yes || echo no)"
bashio::log.info "  /homeassistant/configuration.yaml: $([ -f /homeassistant/configuration.yaml ] && echo yes || echo no)"
bashio::log.info "  /config exists: $([ -d /config ] && echo yes || echo no)"
bashio::log.info "  /config/configuration.yaml: $([ -f /config/configuration.yaml ] && echo yes || echo no)"

if [ -f "/homeassistant/configuration.yaml" ]; then
    HA_CONFIG="/homeassistant"
elif [ -f "/config/configuration.yaml" ]; then
    HA_CONFIG="/config"
else
    bashio::log.error "Cannot find HA config dir (no configuration.yaml in /homeassistant or /config)!"
    bashio::log.error "Add-on cannot install the custom integration. Check add-on map settings."
    exec sleep infinity
fi

bashio::log.info "HA config directory: ${HA_CONFIG}"

COMPONENT_SRC="/usr/src/custom_components/lemonade_ha"
COMPONENT_DEST="${HA_CONFIG}/custom_components/lemonade_ha"

mkdir -p "${HA_CONFIG}/custom_components"

if [ ! -d "${COMPONENT_DEST}" ] || ! diff -rq "${COMPONENT_SRC}" "${COMPONENT_DEST}" > /dev/null 2>&1; then
    bashio::log.info "Installing/updating Lemonade HA custom integration ..."
    rm -rf "${COMPONENT_DEST}"
    cp -r "${COMPONENT_SRC}" "${COMPONENT_DEST}"
    bashio::log.info "Custom integration installed to: ${COMPONENT_DEST}"
    bashio::log.warning "*** Restart Home Assistant (not the add-on) to load the integration. ***"
    bashio::log.warning "Then: Settings > Devices & Services > Add Integration > search 'Lemonade'."
else
    bashio::log.info "Lemonade HA custom integration is already up to date at: ${COMPONENT_DEST}"
fi

bashio::log.info "Add-on running. Integration is managed by Home Assistant."

# Sleep forever — s6 keeps this process alive; the actual work is done by the
# integration inside HA core, not inside this container.
exec sleep infinity
